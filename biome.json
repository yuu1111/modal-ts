{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"extends": ["@yuu1111/biome-config/biome"],
	"files": {
		"includes": [
			"src/**",
			"!src/generated",
			"test/**",
			"examples/**",
			"*.config.ts",
			"scripts/**"
		]
	},
	"linter": {
		"rules": {
			"style": {
				"useShorthandAssign": "error"
			},
			"performance": {
				"noBarrelFile": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["test/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noTemplateCurlyInString": "off"
					}
				}
			}
		}
	]
}
