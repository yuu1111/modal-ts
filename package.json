{
  "name": "modal-ts",
  "version": "0.8.0",
  "description": "Unofficial Modal SDK for JavaScript/TypeScript",
  "license": "Apache-2.0",
  "homepage": "https://github.com/yuu1111/modal-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuu1111/modal-ts.git"
  },
  "bugs": "https://github.com/yuu1111/modal-ts/issues",
  "type": "module",
  "sideEffects": false,
  "files": [
    "/dist"
  ],
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write --unsafe .",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "bun run typecheck",
    "docs": "typedoc --entryPoints src/index.ts --out .typedoc",
    "proto": "bun scripts/gen-proto.ts"
  },
  "dependencies": {
    "cbor-x": "^1.6.4",
    "long": "^5.3.2",
    "nice-grpc": "^2.1.14",
    "protobufjs": "^8.0.1",
    "smol-toml": "^1.6.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@yuu1111/biome-config": "^1.0.4",
    "@yuu1111/tsconfig": "^1.0.3",
    "grpc-tools": "^1.13.1",
    "http-server": "^14.1.1",
    "jsonwebtoken": "^9.0.3",
    "p-queue": "^9.1.2",
    "ts-proto": "^2.11.6",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
